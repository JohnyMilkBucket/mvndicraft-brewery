{
  "name": "mvndicraft-brewery",
  "version": "1.0.7",
  "description": "MvndiCraft Brewery Companion",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.mvndicraft.brewery",
    "productName": "MvndiCraft Brewery",
    "artifactName": "MvndiCraft-Setup.exe",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "shortcutName": "MvndiCraft Brewery"
    },
    "files": ["src/**", "assets/**", "main.js", "preload.js"]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
