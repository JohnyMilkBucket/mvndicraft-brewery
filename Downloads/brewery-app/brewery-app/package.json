{
  "name": "mvndicraft-brewery",
  "version": "1.0.0",
  "description": "MvndiCraft Brewery Guide — recipe tracker, barrel manager & timers",
  "main": "main.js",
  "author": "MvndiCraft",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "net.mvndicraft.brewery",
    "productName": "MvndiCraft Brewery",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico",
      "publisherName": "MvndiCraft"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": false,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MvndiCraft Brewery",
      "artifactName": "MvndiCraft-Brewery-Setup.exe"
    }
  }
}
